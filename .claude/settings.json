{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/go_fmt_lint.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/markdown_lint.sh"
          }
        ]
      }
    ]
  }
}
